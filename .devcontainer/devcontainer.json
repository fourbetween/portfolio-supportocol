{
  "name": "app-supportocol",
  "dockerComposeFile": ["docker-compose.yml"],
  "service": "app",
  "workspaceFolder": "/sources/app-supportocol",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-ceintl.vscode-language-pack-ja",
        "esbenp.prettier-vscode",
        "golang.go",
        "redhat.vscode-yaml",
        "runem.lit-plugin",
        "vitest.explorer"
      ]
    }
  },
  "postCreateCommand": {
    "install-opencode": "curl -fsSL https://opencode.ai/install | bash"
  },
  "mounts": [
    "source=${localEnv:HOME}/.local/share/opencode/auth.json,target=/root/.local/share/opencode/auth.json,type=bind"
  ]
}

{
  "name": "app-supportocol",
  "dockerComposeFile": ["docker-compose.yml"],
  "service": "app",
  "workspaceFolder": "/sources/app-supportocol",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-ceintl.vscode-language-pack-ja",
        "esbenp.prettier-vscode",
        "golang.go",
        "redhat.vscode-yaml",
        "ms-vscode.live-server",
        "runem.lit-plugin",
        "vitest.explorer",
        "GitHub.vscode-pull-request-github"
      ],
      "mcp": {
        "servers": {
          "postgres": {
            "command": "npx",
            "args": [
              "-y",
              "@modelcontextprotocol/server-postgres",
              "postgresql://postgres:password@db:5432/app-supportocol"
            ]
          }
        }
      }
    }
  }
}

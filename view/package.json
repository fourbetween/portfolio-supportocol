{
  "name": "app-supportocol",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --mode=$npm_config_mode",
    "build": "tsc && vite build --mode=$npm_config_mode",
    "test": "vitest --run",
    "preview": "vite preview",
    "gen": "npm run gen:identity && npm run gen:learning && npm run gen:dialogue && npm run gen:workspace",
    "gen:identity": "npx openapi-typescript ../internal/identity/api/schema/openapi.yml -o ./src/feature/identity/api/schema.d.ts",
    "gen:learning": "npx openapi-typescript ../internal/learning/api/schema/openapi.yml -o ./src/feature/learning/api/schema.d.ts",
    "gen:dialogue": "npx openapi-typescript ../internal/dialogue/api/schema/openapi.yml -o ./src/feature/dialogue/api/schema.d.ts",
    "gen:workspace": "npx openapi-typescript ../internal/workspace/api/schema/openapi.yml -o ./src/feature/workspace/api/schema.d.ts",
    "localize:extract": "lit-localize extract",
    "localize:build": "lit-localize build",
    "storybook": "storybook dev --no-open",
    "build-storybook": "storybook build",
    "check:lit": "lit-analyzer \"src/**/*.ts\""
  },
  "dependencies": {
    "@lit-labs/router": "^0.1.4",
    "@lit/context": "^1.1.6",
    "@lit/localize": "^0.12.2",
    "@lit/task": "^1.0.3",
    "lit": "^3.3.2",
    "openapi-fetch": "^0.17.0",
    "urlpattern-polyfill": "^10.1.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@lit/localize-tools": "^0.8.1",
    "@storybook/addon-a11y": "^10.2.10",
    "@storybook/addon-docs": "^10.2.10",
    "@storybook/addon-vitest": "^10.2.10",
    "@storybook/web-components-vite": "^10.2.10",
    "@types/google.accounts": "^0.0.18",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "lit-analyzer": "^2.0.3",
    "playwright": "^1.58.2",
    "rollup-plugin-visualizer": "^6.0.5",
    "storybook": "^10.2.10",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "minimatch": "^10.2.1"
  }
}

{
  "name": "app-supportocol",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --mode=$npm_config_mode",
    "build": "tsc && vite build --mode=$npm_config_mode",
    "preview": "vite preview",
    "gen": "npm run gen:identity && npm run gen:learning",
    "gen:identity": "npx openapi-typescript ../internal/identity/api/schema/openapi.yml -o ./src/api/identity/schema.d.ts",
    "gen:learning": "npx openapi-typescript ../internal/learning/api/schema/openapi.yml -o ./src/api/learning/schema.d.ts",
    "storybook": "storybook dev --no-open",
    "build-storybook": "storybook build",
    "check:lit": "npx lit-analyzer \"src/**/*.ts\""
  },
  "dependencies": {
    "@lit-labs/router": "^0.1.4",
    "@lit/context": "^1.1.6",
    "@lit/task": "^1.0.3",
    "lit": "^3.3.1",
    "openapi-fetch": "^0.15.0",
    "urlpattern-polyfill": "^10.1.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.3",
    "@storybook/addon-a11y": "^10.0.8",
    "@storybook/addon-docs": "^10.0.8",
    "@storybook/addon-vitest": "^10.0.8",
    "@storybook/web-components-vite": "^10.0.8",
    "@types/google.accounts": "^0.0.18",
    "@vitest/browser-playwright": "^4.0.12",
    "@vitest/coverage-v8": "^4.0.12",
    "lit-analyzer": "^2.0.3",
    "playwright": "^1.56.1",
    "storybook": "^10.0.8",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vite-plugin-pwa": "^1.1.0",
    "vitest": "^4.0.12"
  }
}
